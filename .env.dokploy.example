APP_NAME="GESTIÓN ACADÉMICA"
APP_ENV=production
APP_KEY=
APP_DEBUG=false
APP_URL=https://planes.asyservicios.site

APP_LOCALE=es
APP_FALLBACK_LOCALE=es
APP_FAKER_LOCALE=es_ES

APP_MAINTENANCE_DRIVER=file

LOG_CHANNEL=stderr
LOG_STACK=single
LOG_LEVEL=info

DB_CONNECTION=mysql
DB_HOST=gestionplanes-gestionplanes-eebo0l
DB_PORT=3306
DB_DATABASE=planes
DB_USERNAME=planes
DB_PASSWORD=

SESSION_DRIVER=redis
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_COOKIE=gestionplanes_session
SESSION_PATH=/
# Leave empty to scope the session cookie to the current host.
# Do not use the literal string "null".
SESSION_DOMAIN=
SESSION_SECURE_COOKIE=true

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=public
QUEUE_CONNECTION=redis

CACHE_STORE=redis

REDIS_CLIENT=phpredis
REDIS_HOST=redis
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

SSO_DISCOVERY_URL=https://auth.iedagropivijay.edu.co/.well-known/openid-configuration
SSO_ISSUER=https://auth.iedagropivijay.edu.co
SSO_CLIENT_ID=
SSO_CLIENT_SECRET=
SSO_REDIRECT_URI=https://planes.asyservicios.site/sso/callback
SSO_SCOPES="openid email profile"
SSO_PROMPT=login
SSO_SESSION_CHECK_ENABLED=true
SSO_SESSION_CHECK_INTERVAL_SECONDS=60
SSO_SESSION_CHECK_TIMEOUT_SECONDS=12
SSO_SESSION_CHECK_PROMPT=none
SSO_IDP_LOGOUT_URL=https://auth.iedagropivijay.edu.co/logout
SSO_CLIENT_KEY=gestionplanes
SSO_FRONTCHANNEL_LOGOUT_CLIENT_KEY=gestionplanes
SSO_FRONTCHANNEL_LOGOUT_SECRET=
SSO_FRONTCHANNEL_LOGOUT_TTL_SECONDS=120
SSO_FRONTCHANNEL_LOGOUT_NEXT_HOSTS=planes.asyservicios.site,auth.iedagropivijay.edu.co
SSO_HTTP_TIMEOUT=10
