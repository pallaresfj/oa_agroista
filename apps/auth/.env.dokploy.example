APP_NAME="Auth SSO"
APP_ENV=production
APP_KEY=
APP_DEBUG=false
APP_URL=https://auth.<dominio>

APP_LOCALE=es
APP_FALLBACK_LOCALE=es
APP_FAKER_LOCALE=es_ES
APP_TIMEZONE=America/Bogota
APP_MAINTENANCE_DRIVER=file

LOG_CHANNEL=stderr
LOG_STACK=single
LOG_LEVEL=info

DB_CONNECTION=mysql
DB_HOST=mysql-shared
DB_PORT=3306
DB_DATABASE=db_auth
DB_USERNAME=auth_user
DB_PASSWORD=

SESSION_DRIVER=redis
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_COOKIE=auth_sso_session
SESSION_PATH=/
# Leave empty to scope the session cookie to the current host.
# Do not use the literal string "null".
SESSION_DOMAIN=
SESSION_SECURE_COOKIE=true
SESSION_HTTP_ONLY=true
SESSION_SAME_SITE=lax

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=public
QUEUE_CONNECTION=redis
CACHE_STORE=redis

REDIS_CLIENT=phpredis
REDIS_HOST=redis-shared
REDIS_PASSWORD=null
REDIS_PORT=6379
REDIS_PREFIX=auth_

MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="noreply@<dominio>"
MAIL_FROM_NAME="${APP_NAME}"

GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=https://auth.<dominio>/auth/google/callback
GOOGLE_SESSION_CHECK_REDIRECT_URI=https://auth.<dominio>/auth/google/session-check/callback

ISSUER=https://auth.<dominio>
OIDC_FORCE_HTTPS=true
OIDC_KEY_ID=passport-rsa-1

INSTITUTION_EMAIL_DOMAIN=<dominio>
INSTITUTION_CODE=institucionx
INSTITUTION_DEFAULT_NAME="Institucion X"
INSTITUTION_DEFAULT_NIT=
INSTITUTION_DEFAULT_LOGO_URL=
INSTITUTION_DEFAULT_PRIMARY_COLOR=#f50404
INSTITUTION_DEFAULT_SUCCESS_COLOR=#00c853
INSTITUTION_DEFAULT_INFO_COLOR=#0288d1
INSTITUTION_DEFAULT_WARNING_COLOR=#ff9800
INSTITUTION_DEFAULT_DANGER_COLOR=#b71c1c

PLANES_BASE_URL=https://planes.<dominio>
PLANES_CLIENT_ID=
PLANES_CLIENT_SECRET=
ASISTENCIA_BASE_URL=https://asistencia.<dominio>
ASISTENCIA_CLIENT_ID=
ASISTENCIA_CLIENT_SECRET=
SILO_BASE_URL=https://silo.<dominio>
SILO_CLIENT_ID=
SILO_CLIENT_SECRET=

TOKEN_TTL_MINUTES=30
REFRESH_TOKEN_TTL_DAYS=14

CORS_ALLOWED_ORIGINS=https://planes.<dominio>,https://asistencia.<dominio>,https://silo.<dominio>
SSO_ALLOWED_REDIRECT_HOSTS=planes.<dominio>,asistencia.<dominio>,silo.<dominio>,auth.<dominio>
SSO_INSECURE_REDIRECT_HOSTS=
SSO_POST_LOGOUT_REDIRECT_HOSTS=planes.<dominio>,asistencia.<dominio>,silo.<dominio>,auth.<dominio>
SSO_FRONTCHANNEL_LOGOUT_CLIENTS=planes|https://planes.<dominio>/sso/frontchannel-logout,asistencia|https://asistencia.<dominio>/sso/frontchannel-logout,silo|https://silo.<dominio>/sso/frontchannel-logout
SSO_FRONTCHANNEL_LOGOUT_SECRETS=planes|change-me,asistencia|change-me,silo|change-me
SSO_FRONTCHANNEL_LOGOUT_TTL_SECONDS=120

GOOGLE_LOGOUT_FROM_BROWSER=true
GOOGLE_SESSION_CHECK_ENABLED=true
GOOGLE_SESSION_CHECK_INTERVAL_SECONDS=60
GOOGLE_SESSION_CHECK_TIMEOUT_SECONDS=8
