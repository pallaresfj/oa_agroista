APP_NAME="Auth SSO"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=https://oa-auth.test

APP_LOCALE=es
APP_FALLBACK_LOCALE=es
APP_FAKER_LOCALE=es_ES
APP_TIMEZONE=America/Bogota

APP_MAINTENANCE_DRIVER=file

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=auth_sso
DB_USERNAME=root
DB_PASSWORD=

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_COOKIE=auth_sso_session
SESSION_PATH=/
SESSION_DOMAIN=null
SESSION_SECURE_COOKIE=true
SESSION_HTTP_ONLY=true
SESSION_SAME_SITE=lax

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

CACHE_STORE=database

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="noreply@iedagropivijay.edu.co"
MAIL_FROM_NAME="${APP_NAME}"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

VITE_APP_NAME="${APP_NAME}"

# Google OAuth (Socialite)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=https://oa-auth.test/auth/google/callback
GOOGLE_SESSION_CHECK_REDIRECT_URI=https://oa-auth.test/auth/google/session-check/callback

# OIDC / SSO
ISSUER=https://oa-auth.test
OIDC_FORCE_HTTPS=true
OIDC_KEY_ID=passport-rsa-1
INSTITUTION_EMAIL_DOMAIN=iedagropivijay.edu.co
INSTITUTION_CODE=institucionx
INSTITUTION_DEFAULT_NAME="Institucion X"
INSTITUTION_DEFAULT_NIT=
INSTITUTION_DEFAULT_LOGO_URL=
INSTITUTION_DEFAULT_PRIMARY_COLOR=#f50404
INSTITUTION_DEFAULT_SUCCESS_COLOR=#00c853
INSTITUTION_DEFAULT_INFO_COLOR=#0288d1
INSTITUTION_DEFAULT_WARNING_COLOR=#ff9800
INSTITUTION_DEFAULT_DANGER_COLOR=#b71c1c
PLANES_BASE_URL=https://oa-planes.test
PLANES_CLIENT_ID=019ccb79-60df-7038-8f27-4e6dd4a68c60
PLANES_CLIENT_SECRET=planes-local-secret
ASISTENCIA_BASE_URL=https://oa-asistencia.test
ASISTENCIA_CLIENT_ID=019ccb79-61b5-7018-abdb-4ae22d9922a1
ASISTENCIA_CLIENT_SECRET=asistencia-local-secret
SILO_BASE_URL=https://oa-silo.test
SILO_CLIENT_ID=019ccb79-6289-724c-9fdf-fb486d4a3545
SILO_CLIENT_SECRET=silo-local-secret
TOKEN_TTL_MINUTES=30
REFRESH_TOKEN_TTL_DAYS=14
CORS_ALLOWED_ORIGINS=https://oa-planes.test,https://oa-asistencia.test,https://oa-silo.test
SSO_ALLOWED_REDIRECT_HOSTS=oa-planes.test,oa-asistencia.test,oa-silo.test,localhost,127.0.0.1
SSO_INSECURE_REDIRECT_HOSTS=localhost,127.0.0.1
SSO_POST_LOGOUT_REDIRECT_HOSTS=oa-planes.test,oa-asistencia.test,oa-silo.test,localhost,127.0.0.1,oa-auth.test
SSO_FRONTCHANNEL_LOGOUT_CLIENTS=silo|https://oa-silo.test/sso/frontchannel-logout
SSO_FRONTCHANNEL_LOGOUT_SECRETS=silo|change-me-local-secret
SSO_FRONTCHANNEL_LOGOUT_TTL_SECONDS=120
GOOGLE_LOGOUT_FROM_BROWSER=true
GOOGLE_SESSION_CHECK_ENABLED=true
GOOGLE_SESSION_CHECK_INTERVAL_SECONDS=60
GOOGLE_SESSION_CHECK_TIMEOUT_SECONDS=8
