# Application
APP_NAME=Laravel
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=https://oa-silo.test

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

# PHP_CLI_SERVER_WORKERS=4

VITE_APP_NAME="${APP_NAME}"

# Security and logging
BCRYPT_ROUNDS=12
LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

# Database
DB_CONNECTION=sqlite
# DB_HOST=127.0.0.1
# DB_PORT=3306
# DB_DATABASE=laravel
# DB_USERNAME=root
# DB_PASSWORD=

# Session, queue and cache
SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_COOKIE=oa_silo_session
SESSION_PATH=/
SESSION_DOMAIN=null
SESSION_SECURE_COOKIE=true

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

CACHE_STORE=database
# CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

# Mail
MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

# AWS
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

# Google OAuth
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI="${APP_URL}/auth/google/callback"
GOOGLE_ALLOWED_DOMAIN=iedagropivijay.edu.co
GOOGLE_LOGOUT_FROM_BROWSER=false

# Google service account (Drive + Workspace validation)
GOOGLE_DRIVE_TYPE=service_account
GOOGLE_DRIVE_PROJECT_ID=
GOOGLE_DRIVE_PRIVATE_KEY_ID=
GOOGLE_DRIVE_PRIVATE_KEY=
GOOGLE_DRIVE_CLIENT_EMAIL=
GOOGLE_DRIVE_CLIENT_ID=
GOOGLE_DRIVE_FOLDER_ID=

GOOGLE_DRIVE_TEMPLATE_DOCUMENT_ID=
GOOGLE_DRIVE_TEMPLATE_SPREADSHEET_ID=
GOOGLE_DRIVE_TEMPLATE_PRESENTATION_ID=

GOOGLE_WORKSPACE_ADMIN_EMAIL=
GOOGLE_WORKSPACE_CUSTOMER=my_customer
GOOGLE_WORKSPACE_VALIDATE_USERS_ON_CREATE=true

# Drive sync
DRIVE_SYNC_ENABLED=true
DRIVE_SYNC_NOTIFY=true
DRIVE_SYNC_NOTIFY_ROLES=administrador,rector
DRIVE_SYNC_BOOTSTRAP_ON_EMPTY_STATE=true

# OIDC / SSO (auth as Identity Provider)
SSO_DISCOVERY_URL=https://oa-auth.test/.well-known/openid-configuration
SSO_ISSUER=https://oa-auth.test
SSO_CLIENT_ID=
SSO_CLIENT_SECRET=
INSTITUTION_CODE=institucionx
SSO_REDIRECT_URI=https://oa-silo.test/sso/callback
SSO_SCOPES="openid email profile"
SSO_PROMPT=login
SSO_SESSION_CHECK_ENABLED=true
SSO_SESSION_CHECK_INTERVAL_SECONDS=60
SSO_SESSION_CHECK_PROMPT=none
SSO_IDP_LOGOUT_URL=https://oa-auth.test/logout
SSO_FRONTCHANNEL_LOGOUT_CLIENT_KEY=silo
SSO_FRONTCHANNEL_LOGOUT_SECRET=change-me-local-secret
SSO_FRONTCHANNEL_LOGOUT_TTL_SECONDS=120
SSO_FRONTCHANNEL_LOGOUT_NEXT_HOSTS=localhost,127.0.0.1,oa-auth.test,oa-silo.test,oa-planes.test,oa-asistencia.test,accounts.google.com,appengine.google.com
SSO_HTTP_TIMEOUT=10
AUTH_API_BASE=https://oa-auth.test/api/ecosystem
