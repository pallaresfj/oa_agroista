APP_NAME="SILO"
APP_ENV=production
APP_KEY=
APP_DEBUG=false
APP_URL=https://silo.<dominio>

APP_LOCALE=es
APP_FALLBACK_LOCALE=es
APP_FAKER_LOCALE=es_ES
APP_MAINTENANCE_DRIVER=file

LOG_CHANNEL=stderr
LOG_STACK=single
LOG_LEVEL=info

DB_CONNECTION=mysql
# In Dokploy use the MySQL "Internal Host" value (e.g. mysql-shared-xxxxxx).
DB_HOST=mysql-shared
DB_PORT=3306
DB_DATABASE=db_silo
DB_USERNAME=silo_user
DB_PASSWORD=

SESSION_DRIVER=redis
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_COOKIE=oa_silo_session
SESSION_PATH=/
# Leave empty to scope the session cookie to the current host.
# Do not use the literal string "null".
SESSION_DOMAIN=
SESSION_SECURE_COOKIE=true

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=public
QUEUE_CONNECTION=redis
CACHE_STORE=redis

REDIS_CLIENT=phpredis
# In Dokploy use the Redis "Internal Host" value (e.g. redis-shared-xxxxxx).
REDIS_HOST=redis-shared
REDIS_PASSWORD=null
REDIS_PORT=6379
REDIS_PREFIX=silo_

MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=https://silo.<dominio>/auth/google/callback
GOOGLE_ALLOWED_DOMAIN=
GOOGLE_LOGOUT_FROM_BROWSER=false

GOOGLE_DRIVE_TYPE=service_account
GOOGLE_DRIVE_PROJECT_ID=
GOOGLE_DRIVE_PRIVATE_KEY_ID=
GOOGLE_DRIVE_PRIVATE_KEY=
GOOGLE_DRIVE_CLIENT_EMAIL=
GOOGLE_DRIVE_CLIENT_ID=
GOOGLE_DRIVE_FOLDER_ID=
GOOGLE_DRIVE_TEMPLATE_DOCUMENT_ID=
GOOGLE_DRIVE_TEMPLATE_SPREADSHEET_ID=
GOOGLE_DRIVE_TEMPLATE_PRESENTATION_ID=
GOOGLE_WORKSPACE_ADMIN_EMAIL=
GOOGLE_WORKSPACE_CUSTOMER=my_customer
GOOGLE_WORKSPACE_VALIDATE_USERS_ON_CREATE=true

DRIVE_SYNC_ENABLED=true
DRIVE_SYNC_NOTIFY=true
DRIVE_SYNC_NOTIFY_ROLES=soporte,directivo
DRIVE_SYNC_BOOTSTRAP_ON_EMPTY_STATE=true

# Auto-bootstrap roles/permissions and support user at web startup (recommended in Dokploy).
SILO_BOOTSTRAP_ON_START=true
SILO_BOOTSTRAP_MAX_TRIES=20
SILO_BOOTSTRAP_SLEEP_SECONDS=3

SSO_DISCOVERY_URL=https://auth.<dominio>/.well-known/openid-configuration
SSO_ISSUER=https://auth.<dominio>
SSO_CLIENT_ID=
SSO_CLIENT_SECRET=
INSTITUTION_CODE=institucionx
SSO_REDIRECT_URI=https://silo.<dominio>/sso/callback
SSO_SCOPES="openid email profile"
SSO_PROMPT=login
SSO_SESSION_CHECK_ENABLED=true
SSO_SESSION_CHECK_INTERVAL_SECONDS=60
SSO_SESSION_CHECK_PROMPT=none
SSO_IDP_LOGOUT_URL=https://auth.<dominio>/logout
SSO_FRONTCHANNEL_LOGOUT_CLIENT_KEY=silo
SSO_FRONTCHANNEL_LOGOUT_SECRET=
SSO_FRONTCHANNEL_LOGOUT_TTL_SECONDS=120
SSO_FRONTCHANNEL_LOGOUT_NEXT_HOSTS=auth.<dominio>,silo.<dominio>,planes.<dominio>,asistencia.<dominio>,accounts.google.com,appengine.google.com
SSO_HTTP_TIMEOUT=10
AUTH_API_BASE=https://auth.<dominio>/api/ecosystem
