{
  "name": "agroista/core",
  "description": "Core integration package for Agroista ecosystem applications",
  "version": "1.0.0",
  "type": "library",
  "license": "MIT",
  "require": {
    "php": "^8.2",
    "illuminate/support": "^12.0",
    "illuminate/http": "^12.0",
    "illuminate/cache": "^12.0",
    "firebase/php-jwt": "^6.10"
  },
  "autoload": {
    "psr-4": {
      "Agroista\\Core\\": "src/"
    }
  },
  "extra": {
    "laravel": {
      "providers": [
        "Agroista\\Core\\CoreServiceProvider"
      ]
    }
  },
  "minimum-stability": "stable",
  "prefer-stable": true
}
