APP_NAME="ASISTENCIA"
APP_ENV=production
APP_KEY=
APP_DEBUG=false
APP_URL=https://asistencia.<dominio>

APP_LOCALE=es
APP_FALLBACK_LOCALE=es
APP_FAKER_LOCALE=es_ES
APP_MAINTENANCE_DRIVER=file

LOG_CHANNEL=stderr
LOG_STACK=single
LOG_LEVEL=info

DB_CONNECTION=mysql
# In Dokploy use the MySQL "Internal Host" value (e.g. mysql-shared-xxxxxx).
DB_HOST=mysql-shared
DB_PORT=3306
DB_DATABASE=db_asistencia
DB_USERNAME=asistencia_user
DB_PASSWORD=

SESSION_DRIVER=redis
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_COOKIE=oa_asistencia_session
SESSION_PATH=/
# Leave empty to scope the session cookie to the current host.
# Do not use the literal string "null".
SESSION_DOMAIN=
SESSION_SECURE_COOKIE=true

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=public
QUEUE_CONNECTION=redis
CACHE_STORE=redis

REDIS_CLIENT=phpredis
# In Dokploy use the Redis "Internal Host" value (e.g. redis-shared-xxxxxx).
REDIS_HOST=redis-shared
REDIS_PASSWORD=null
REDIS_PORT=6379
REDIS_PREFIX=asistencia_

MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

SSO_DISCOVERY_URL=https://auth.<dominio>/.well-known/openid-configuration
SSO_ISSUER=https://auth.<dominio>
SSO_CLIENT_ID=
SSO_CLIENT_SECRET=
INSTITUTION_CODE=institucionx
SSO_REDIRECT_URI=https://asistencia.<dominio>/sso/callback
SSO_SCOPES="openid email profile"
SSO_SESSION_CHECK_ENABLED=false
SSO_SESSION_WATCHDOG_ENABLED=false
SSO_SESSION_WATCHDOG_INTERVAL_SECONDS=30
SSO_IDP_LOGOUT_URL=https://auth.<dominio>/logout
SSO_FRONTCHANNEL_LOGOUT_CLIENT_KEY=asistencia
SSO_FRONTCHANNEL_LOGOUT_SECRET=
SSO_FRONTCHANNEL_LOGOUT_TTL_SECONDS=120
SSO_FRONTCHANNEL_LOGOUT_NEXT_HOSTS=auth.<dominio>,asistencia.<dominio>,planes.<dominio>,silo.<dominio>,accounts.google.com,appengine.google.com
SSO_HTTP_TIMEOUT=10
AUTH_API_BASE=https://auth.<dominio>/api/ecosystem

# Auto-bootstrap migrations, Shield permissions and seed data at web startup (recommended in Dokploy).
ASISTENCIA_BOOTSTRAP_ON_START=true
ASISTENCIA_BOOTSTRAP_MAX_TRIES=20
ASISTENCIA_BOOTSTRAP_SLEEP_SECONDS=3
