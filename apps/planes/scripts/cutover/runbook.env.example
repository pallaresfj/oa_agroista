# Copy this file to a secure location (outside git) and set real values.

# Source (legacy planes currently in production)
SOURCE_DB_HOST=
SOURCE_DB_PORT=3306
SOURCE_DB_USER=
SOURCE_DB_PASSWORD=
SOURCE_DB_NAME=db_planes

# Target (oa-planes production MySQL)
TARGET_DB_HOST=
TARGET_DB_PORT=3306
TARGET_DB_USER=
TARGET_DB_PASSWORD=
TARGET_DB_NAME=db_planes

# New database for cutover load
# Recommended format: db_planes_cutover_YYYYMMDD
CUTOVER_DB_NAME=

# Local working directory for artifacts generated by manual-cutover.sh
BACKUP_DIR=/tmp/planes-cutover

# Dump file name generated from SOURCE_DB_NAME if empty.
DUMP_FILE=

# Optional: media path in current production (destination before cutover)
MEDIA_TARGET_DIR=

# Optional: colon-separated sources for media sync (plan-cover, center-cover)
# Example: /mnt/legacy/storage/app/public:/mnt/backup/storage/app/public
MEDIA_SYNC_SOURCE_DIRS=

# App path for artisan commands (defaults to apps/planes)
APP_PATH=
