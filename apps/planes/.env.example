APP_NAME="GESTIÓN ACADÉMICA"
APP_ENV=local
APP_KEY=base64:UMBgowCeHta4N2+/BsqHr2/mWuEvL/sp3mVXwluBv0Y=
APP_DEBUG=true
APP_URL=https://oa-planes.test

APP_LOCALE=es
APP_FALLBACK_LOCALE=es
APP_FAKER_LOCALE=es_ES

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=laravel_plan
DB_USERNAME=root
DB_PASSWORD=

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_COOKIE=oa_planes_session
SESSION_PATH=/
# Leave empty to scope the session cookie to the current host.
# Do not use the literal string "null".
SESSION_DOMAIN=
SESSION_SECURE_COOKIE=false

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

CACHE_STORE=database
# CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

VITE_APP_NAME="${APP_NAME}"

# OIDC / SSO (auth as Identity Provider)
SSO_DISCOVERY_URL=https://oa-auth.test/.well-known/openid-configuration
SSO_ISSUER=https://oa-auth.test
SSO_CLIENT_ID=
SSO_CLIENT_SECRET=
# Comma-separated emails that must always be assigned the "Soporte" role on SSO login.
SSO_SUPPORT_EMAILS=pallaresfj@iedagropivijay.edu.co
INSTITUTION_CODE=institucionx
SSO_REDIRECT_URI=https://oa-planes.test/sso/callback
SSO_SCOPES="openid email profile"
SSO_PROMPT=login
SSO_SESSION_CHECK_ENABLED=true
SSO_SESSION_CHECK_INTERVAL_SECONDS=60
SSO_SESSION_CHECK_TIMEOUT_SECONDS=12
SSO_SESSION_CHECK_PROMPT=none
SSO_IDP_LOGOUT_URL=https://oa-auth.test/logout
SSO_CLIENT_KEY=planes
SSO_FRONTCHANNEL_LOGOUT_CLIENT_KEY=planes
SSO_FRONTCHANNEL_LOGOUT_SECRET=
SSO_FRONTCHANNEL_LOGOUT_TTL_SECONDS=120
SSO_FRONTCHANNEL_LOGOUT_NEXT_HOSTS=localhost,127.0.0.1,oa-auth.test,oa-planes.test,oa-asistencia.test,oa-silo.test,accounts.google.com,appengine.google.com
SSO_HTTP_TIMEOUT=10
AUTH_API_BASE=https://oa-auth.test/api/ecosystem

# Auto-bootstrap roles/permissions at web container startup.
PLANES_BOOTSTRAP_ON_START=true
PLANES_BOOTSTRAP_MAX_TRIES=20
PLANES_BOOTSTRAP_SLEEP_SECONDS=3
