APP_NAME=Lectura
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=https://oa-lectura.test

APP_LOCALE=es
APP_FALLBACK_LOCALE=es
APP_FAKER_LOCALE=es_ES

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

# PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=sqlite
# DB_HOST=127.0.0.1
# DB_PORT=3306
# DB_DATABASE=laravel
# DB_USERNAME=root
# DB_PASSWORD=

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_COOKIE=oa_lectura_session
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

CACHE_STORE=database
# CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

VITE_APP_NAME="${APP_NAME}"

# OIDC / SSO (auth as Identity Provider)
SSO_DISCOVERY_URL=https://oa-auth.test/.well-known/openid-configuration
SSO_ISSUER=https://oa-auth.test
SSO_CLIENT_ID=
SSO_CLIENT_SECRET=
INSTITUTION_CODE=institucionx
SSO_REDIRECT_URI=https://oa-lectura.test/sso/callback
SSO_SCOPES="openid email profile"
SSO_SESSION_CHECK_ENABLED=false
SSO_SESSION_WATCHDOG_ENABLED=false
SSO_SESSION_WATCHDOG_INTERVAL_SECONDS=30
SSO_IDP_LOGOUT_URL=https://oa-auth.test/logout
SSO_FRONTCHANNEL_LOGOUT_CLIENT_KEY=lectura
SSO_FRONTCHANNEL_LOGOUT_SECRET=change-me-local-secret
SSO_FRONTCHANNEL_LOGOUT_TTL_SECONDS=120
SSO_FRONTCHANNEL_LOGOUT_NEXT_HOSTS=localhost,127.0.0.1,oa-auth.test,oa-lectura.test,oa-silo.test,oa-planes.test,accounts.google.com,appengine.google.com
SSO_HTTP_TIMEOUT=10
AUTH_API_BASE=https://oa-auth.test/api/ecosystem
LECTURA_ADMIN_EMAIL=admin@institucion.edu.co
